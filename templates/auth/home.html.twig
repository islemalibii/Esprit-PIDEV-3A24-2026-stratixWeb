{% extends 'base_auth.html.twig' %}
{% block title %}Accueil{% endblock %}
{% block body %}
<div style="max-width:600px;margin:4rem auto;font-family:sans-serif;text-align:center;">
    <h1 style="color:#1e1b4b;">Bonjour, {{ user.prenom }} {{ user.nom }} 👋</h1>
    <p style="color:#6b7280;margin-top:.5rem;">Vous êtes connecté en tant que <strong>{{ user.role }}</strong></p>
    <a href="{{ path('app_logout') }}" style="display:inline-block;margin-top:2rem;padding:.65rem 1.5rem;background:#dc2626;color:#fff;border-radius:8px;text-decoration:none;">
        go to account
    </a>
</div>
{% endblock %}
