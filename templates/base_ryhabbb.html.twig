<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}STRATIX{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">

    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            {# InApp dropdown on the LEFT replacing the brand #}
            <div class="dropdown me-3">
                <a class="btn btn-outline-light btn-sm dropdown-toggle" href="#"
                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-th-large me-1"></i> InApp
                </a>
                <div class="dropdown-menu p-2" style="min-width: 220px;">
                    <h6 class="dropdown-header small text-uppercase text-muted" style="letter-spacing:.06em;">
                        Menu Principal
                    </h6>
                    
                    <a class="dropdown-item rounded-2 py-2" href="{{ path('app_service_index') }}">
                        <i class="ti ti-box-seam me-2 text-muted"></i> Services
                    </a>
                    <a class="dropdown-item rounded-2 py-2" href="{{ path('app_categorie_service_index') }}">
                        <i class="ti ti-plus me-2 text-muted"></i> Catégories
                    </a>
                    <a class="dropdown-item rounded-2 py-2" href="{{ path('produit_index') }}">
                        <i class="ti ti-receipt me-2 text-muted"></i> Produit
                    </a>
                    <a class="dropdown-item rounded-2 py-2" href="{{ path('ressource_index') }}">
                        <i class="ti ti-alert-circle me-2 text-muted"></i> Ressources
                    </a>
                    <a class="dropdown-item rounded-2 py-2" href="{{ path('app_projet_index') }}">
                        <i class="ti ti-file-text me-2 text-muted"></i> Projets
                    </a>
                    <a class="dropdown-item rounded-2 py-2" href="{{ path('resp_event_index') }}">
                        <i class="ti ti-calendar-event me-2 text-muted"></i> Événements
                    </a>
                </div>
            </div>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_dashboard') }}">
                            <i class="fas fa-tachometer-alt"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_tache_index') }}">
                            <i class="fas fa-tasks"></i> Tâches
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_planning_index') }}">
                            <i class="fas fa-calendar-alt"></i> Plannings
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_calendar_index') }}">
                            <i class="fas fa-calendar-week"></i> Calendrier
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_whiteboard_index') }}">
                            <i class="fas fa-chalkboard"></i> Kanban
                        </a>
                    </li>
                </ul>
            </div>

        </div>
    </nav>

    <main class="py-4 container">
        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% endblock %}
</body>
</html>