<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}InApp Inventory Dashboard{% endblock %}</title>

    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('inapp/assets/images/apple-touch-icon.png') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('inapp/assets/images/favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('inapp/assets/images/favicon-16x16.png') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">

    <link rel="manifest" href="{{ asset('inapp/assets/site.webmanifest') }}">

 
    {% block stylesheets %}
            <link rel="stylesheet" crossorigin href="/styles/app.css">
            <style>
                :root {
                    --sidebar-width: 260px;
                    --navbar-height: 70px;
                }

                body {
                    background-color: #f8f9fa;
                    margin: 0;
                    overflow-x: hidden;
                }

                /* Your original pages - use #content or .content */
                #content, .content {
                    margin-left: var(--sidebar-width);
                    padding-top: var(--navbar-height);
                    min-height: 100vh;
                    transition: all 0.3s ease;
                }

                /* Merged pages - use container-fluid directly in body block */
                body > .container-fluid {
                    margin-left: var(--sidebar-width);
                    padding-top: calc(var(--navbar-height) + 1.5rem);
                    padding-left: 2rem;
                    padding-right: 2rem;
                    min-height: 100vh;
                    max-width: 100%;
                }

                @media (max-width: 992px) {
                    #content, .content, body > .container-fluid {
                        margin-left: 0;
                    }
                }
            </style>
        {% endblock %}
</head>
<body>
    <div id="overlay" class="overlay"></div>
    {{ include('admin/partials/navbar.html.twig') }}
    {{ include('admin/partials/sidebar.html.twig') }}
    {% block body %}{% endblock %}

    {% block javascripts %}
        <script src="/inapp/assets/js/main.js"></script>
    {% endblock %}
</body>
</html>