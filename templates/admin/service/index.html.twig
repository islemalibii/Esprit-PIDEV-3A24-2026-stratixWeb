{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Gestion des Services</h1>
        <a href="{{ path('app_service_new') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouveau Service
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-exchange-alt"></i> Convertisseur de Devises
            </h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-12">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Montant en TND</label>
                            <div class="input-group">
                                <input type="number" 
                                       id="montant-tnd" 
                                       class="form-control" 
                                       placeholder="Saisir le montant"
                                       step="0.01"
                                       value="">
                                <span class="input-group-text">DT</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">USD (Dollar Américain)</label>
                            <div class="input-group">
                                <input type="text" 
                                       id="montant-usd" 
                                       class="form-control bg-light" 
                                       readonly>
                                <span class="input-group-text">$</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">EUR (Euro)</label>
                            <div class="input-group">
                                <input type="text" 
                                       id="montant-eur" 
                                       class="form-control bg-light" 
                                       readonly>
                                <span class="input-group-text">€</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary w-100" id="btnConvertir">
                                <i class="fas fa-sync-alt"></i> Convertir
                            </button>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-12">
                            <small class="text-muted">
                                <i class="fas fa-info-circle"></i> 
                                Taux de change mis à jour automatiquement
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Recherche et Filtrage</h6>
        </div>
        <div class="card-body">
            <form method="GET" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="search" class="form-control" placeholder="Rechercher par titre ou description..."
                           value="{{ search }}">
                </div>
                <div class="col-md-3">
                    <select name="categorie" class="form-select">
                        <option value="">Toutes les catégories</option>
                        {% for categorie in categories %}
                            <option value="{{ categorie.nom }}" {{ selectedCategorie == categorie.nom ? 'selected' }}>
                                {{ categorie.nom }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="archive" value="1" id="archiveCheck"
                               {{ showArchives ? 'checked' }}>
                        <label class="form-check-label" for="archiveCheck">
                            Archives
                        </label>
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary me-2">
                        <i class="fas fa-search"></i> Rechercher
                    </button>
                    <a href="{{ path('app_service_index') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-times"></i> Réinitialiser
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        {% for service in services %}
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">{{ service.titre }}</h6>
                        {% if service.categorie %}
                            <span class="badge bg-secondary">{{ service.categorie.nom }}</span>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <div class="row no-gutters align-items-center mb-2">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                    Budget
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">
                                    {{ service.budget|number_format(0, ',', ' ') }} DT
                                </div>
                            </div>
                        </div>
                        <div class="row no-gutters align-items-center mb-2">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                    Période
                                </div>
                                <div class="text-xs text-muted">
                                    {{ service.dateDebut ? service.dateDebut|date('d/m/Y') : 'N/A' }} -
                                    {{ service.dateFin ? service.dateFin|date('d/m/Y') : 'N/A' }}
                                </div>
                            </div>
                        </div>
                        {% if service.description %}
                            <p class="text-muted small mb-3">
                                {{ service.description|slice(0, 100) ~ (service.description|length > 100 ? '...' : '') }}
                            </p>
                        {% endif %}
                    </div>
                    <div class="card-footer">
                        <div class="btn-group w-100" role="group">
                            <a href="{{ path('app_service_show', {'id': service.id}) }}"
                               class="btn btn-sm btn-outline-info">
                                <i class="fas fa-eye"></i> Voir
                            </a>
                            <a href="{{ path('app_service_edit', {'id': service.id}) }}"
                               class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-edit"></i> Modifier
                            </a>
                            <form method="post" action="{{ path('app_service_archive', {'id': service.id}) }}"
                                  class="d-inline"
                                  onsubmit="return confirm('{{ service.archive ? 'Restaurer' : 'Archiver' }} ce service ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('archive' ~ service.id) }}">
                                <button type="submit" class="btn btn-sm {{ service.archive ? 'btn-outline-success' : 'btn-outline-secondary' }}">
                                    <i class="fas fa-{{ service.archive ? 'undo' : 'archive' }}"></i>
                                    {{ service.archive ? 'Restaurer' : 'Archiver' }}
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">Aucun service trouvé</h5>
                        <p class="text-muted">Il n'y a pas de services {{ showArchives ? 'archivés' : 'actifs' }} correspondant à vos critères.</p>
                        <a href="{{ path('app_service_new') }}" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Créer le premier service
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const tndInput = document.getElementById('montant-tnd');
    const usdInput = document.getElementById('montant-usd');
    const eurInput = document.getElementById('montant-eur');
    const btnConvertir = document.getElementById('btnConvertir');
    
    let tauxUSD = null;
    let tauxEUR = null;
    
  
    const DEFAULT_TND_TO_USD = 3.0;
    const DEFAULT_TND_TO_EUR = 3.2;
    
    function fetchExchangeRates() {
      
        fetch('{{ path('api_exchange_rates') }}')
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    tauxUSD = data.rates.USD;
                    tauxEUR = data.rates.EUR;
                    console.log('Taux chargés avec succès:', tauxUSD, tauxEUR);
                    convertCurrency();
                } else {
                    throw new Error('API error');
                }
            })
            .catch(error => {
                console.log('Utilisation des taux par défaut');
              
                tauxUSD = DEFAULT_TND_TO_USD;
                tauxEUR = DEFAULT_TND_TO_EUR;
                convertCurrency();
            });
    }
    
    
    function convertCurrency() {
        let montantTND = parseFloat(tndInput.value);
        
        if (isNaN(montantTND)) {
            montantTND = 0;
        }
        
        if (tauxUSD && tauxEUR) {
           
            usdInput.value = (montantTND / tauxUSD).toFixed(2);
            eurInput.value = (montantTND / tauxEUR).toFixed(2);
        } else {
            usdInput.value = (montantTND / DEFAULT_TND_TO_USD).toFixed(2);
            eurInput.value = (montantTND / DEFAULT_TND_TO_EUR).toFixed(2);
        }
    }
    
    btnConvertir.addEventListener('click', convertCurrency);
    tndInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            convertCurrency();
        }
    });
    
   
    let autoConvertInterval;
    tndInput.addEventListener('focus', function() {
        autoConvertInterval = setInterval(convertCurrency, 30000);
    });
    
    tndInput.addEventListener('blur', function() {
        if (autoConvertInterval) {
            clearInterval(autoConvertInterval);
        }
    });
    
    fetchExchangeRates();
    
    setInterval(fetchExchangeRates, 3600000);
});
</script>
{% endblock %}
{% endblock %}