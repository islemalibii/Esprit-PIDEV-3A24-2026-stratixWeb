{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Détails du Service</h1>
        <div>
            <a href="{{ path('app_service_edit', {'id': service.id}) }}" class="btn btn-warning me-2">
                <i class="fas fa-edit"></i> Modifier
            </a>
            <a href="{{ path('app_service_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour à la liste
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-8 col-lg-10">
            <div class="card shadow">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">{{ service.titre }}</h6>
                    {% if service.archive %}
                        <span class="badge bg-secondary">Archivé</span>
                    {% else %}
                        <span class="badge bg-success">Actif</span>
                    {% endif %}
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <strong class="text-primary">Titre:</strong>
                                <p>{{ service.titre }}</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <strong class="text-primary">Catégorie:</strong>
                                <p>
                                    {% if service.categorie %}
                                        <span class="badge bg-info">{{ service.categorie.nom }}</span>
                                    {% else %}
                                        <span class="text-muted">Non catégorisé</span>
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </div>

                    {% if service.description %}
                        <div class="mb-3">
                            <strong class="text-primary">Description:</strong>
                            <p>{{ service.description }}</p>
                        </div>
                    {% endif %}

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <strong class="text-primary">Budget:</strong>
                                <p class="h5 text-success">{{ service.budget|number_format(0, ',', ' ') }} DT</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <strong class="text-primary">Date de début:</strong>
                                <p>{{ service.dateDebut ? service.dateDebut|date('d/m/Y') : 'Non définie' }}</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <strong class="text-primary">Date de fin:</strong>
                                <p>{{ service.dateFin ? service.dateFin|date('d/m/Y') : 'Non définie' }}</p>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <strong class="text-primary">Date de création:</strong>
                                <p>{{ service.dateCreation ? service.dateCreation|date('d/m/Y H:i') : 'Non définie' }}</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <strong class="text-primary">Responsable:</strong>
                                <p>
                                    {% if service.utilisateur %}
                                        {{ service.utilisateur.prenom }} {{ service.utilisateur.nom }}
                                        {% if service.utilisateur.email %}
                                            <br><small class="text-muted">{{ service.utilisateur.email }}</small>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">Non assigné</span>
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="btn-group" role="group">
                        <a href="{{ path('app_service_edit', {'id': service.id}) }}" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        <form method="post" action="{{ path('app_service_archive', {'id': service.id}) }}"
                              class="d-inline ms-2"
                              onsubmit="return confirm('{{ service.archive ? 'Restaurer' : 'Archiver' }} ce service ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('archive' ~ service.id) }}">
                            <button type="submit" class="btn {{ service.archive ? 'btn-success' : 'btn-secondary' }}">
                                <i class="fas fa-{{ service.archive ? 'undo' : 'archive' }}"></i>
                                {{ service.archive ? 'Restaurer' : 'Archiver' }}
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_service_delete', {'id': service.id}) }}"
                              class="d-inline ms-2"
                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce service ? Cette action est irréversible.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ service.id) }}">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}