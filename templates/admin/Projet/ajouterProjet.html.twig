{% extends 'base.html.twig' %}

{% block title %}STRATIX - Nouveau Projet{% endblock %}

{% block body %}
<div id="overlay" class="overlay"></div>

<nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <div class="d-flex align-items-center w-100">
        <button id="toggleBtn" class="btn btn-light btn-sm me-3">
            <i class="ti ti-menu-2"></i>
        </button>
        <div class="ms-auto d-flex align-items-center gap-3">
            <div class="position-relative">
                <i class="ti ti-bell fs-4 text-secondary"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">2</span>
            </div>
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.8rem;">
                EZ
            </div>
        </div>
    </div>
</nav>

<aside id="sidebar" class="sidebar">
    <div class="logo-area p-3">
        <div class="d-flex align-items-center">
            <img src="{{ asset('images/logo-icon.svg') }}" alt="Logo" width="30">
            <span class="ms-2 fw-bold text-dark">
                InApp <br>
                <small class="text-muted" style="font-size: 0.7rem;">Inventory App</small>
            </span>
        </div>
    </div>
    
    <div class="px-3 mt-4">
        <p class="text-muted small text-uppercase fw-bold mb-2" style="font-size: 0.65rem; letter-spacing: 0.5px;">Menu Principale</p>
        <ul class="nav flex-column gap-1">
            <li class="nav-item">
                <a class="nav-link rounded text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-smart-home me-2 fs-5"></i><span>Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-settings me-2 fs-5"></i><span>Services</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-category me-2 fs-5"></i><span>Categories</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-package me-2 fs-5"></i><span>Produit</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-users me-2 fs-5"></i><span>Ressources</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link active bg-danger-subtle rounded text-danger fw-bold d-flex align-items-center" href="{{ path('app_projet_index') }}">
                    <i class="ti ti-file-code me-2 fs-5"></i><span>Projets</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-calendar-event me-2 fs-5"></i><span>Taches et Planning</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-device-heartbeat me-2 fs-5"></i><span>Evenements</span>
                </a>
            </li>
        </ul>
    </div>
</aside>

<main id="content" class="content mt-5 pt-5">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                
                <div class="mb-4">
                    <h2 class="fs-4 fw-bold text-dark">Créer un Nouveau Projet</h2>
                    <p class="text-muted">Remplissez les informations pour ajouter un projet à STRATIX.</p>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">NOM DU PROJET</label>
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control border-0 bg-light p-3 rounded-3', 'placeholder': 'Entrez le nom du projet...'}}) }}
                            <div class="text-danger mt-1 small">{{ form_errors(form.nom) }}</div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">BUDGET (DT)</label>
                                {{ form_widget(form.budget, {'attr': {'class': 'form-control border-0 bg-light p-3 rounded-3', 'placeholder': '0.00'}}) }}
                                <div class="text-danger mt-1 small">{{ form_errors(form.budget) }}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">STATUT</label>
                                <input type="text" class="form-control border-0 bg-light p-3 rounded-3 fw-bold text-muted" value="Planifié" readonly>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">DATE DE DÉBUT</label>
                                {{ form_widget(form.dateDebut, {
                                    'attr': {
                                        'class': 'form-control border-0 bg-light p-3 rounded-3',
                                        'min': "now"|date("Y-m-d")
                                    }
                                }) }}
                                <div class="text-danger mt-1 small">{{ form_errors(form.dateDebut) }}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">DATE DE FIN</label>
                                {{ form_widget(form.dateFin, {'attr': {'class': 'form-control border-0 bg-light p-3 rounded-3'}}) }}
                                <div class="text-danger mt-1 small">{{ form_errors(form.dateFin) }}</div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">DESCRIPTION</label>
                            {{ form_widget(form.description, {'attr': {'class': 'form-control border-0 bg-light p-3 rounded-3', 'rows': '3', 'placeholder': 'Description du projet...'}}) }}
                            <div class="text-danger mt-1 small">{{ form_errors(form.description) }}</div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-md-8">
                                <button type="submit" class="btn btn-danger w-100 p-3 fw-bold rounded-3 shadow-sm">
                                    <i class="ti ti-device-floppy me-2"></i>CONFIRMER LA CRÉATION
                                </button>
                            </div>
                            <div class="col-md-4">
                                <a href="{{ path('app_projet_index') }}" class="btn btn-light border w-100 p-3 fw-bold rounded-3">
                                    RETOUR
                                </a>
                            </div>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %}