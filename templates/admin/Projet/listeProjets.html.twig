{% extends 'base.html.twig' %}

{% block title %}STRATIX - Liste des Projets{% endblock %}

{% block body %}
<div id="overlay" class="overlay"></div>

<nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <div class="d-flex align-items-center w-100">
        <button id="toggleBtn" class="btn btn-light btn-sm me-3">
            <i class="ti ti-menu-2"></i>
        </button>
        <div class="ms-auto d-flex align-items-center gap-3">
            <div class="position-relative">
                <i class="ti ti-bell fs-4 text-secondary"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">2</span>
            </div>
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.8rem;">
                EZ
            </div>
        </div>
    </div>
</nav>

<aside id="sidebar" class="sidebar">
    <div class="logo-area p-3">
        <div class="d-flex align-items-center">
            <img src="{{ asset('images/logo-icon.svg') }}" alt="Logo" width="30">
            <span class="ms-2 fw-bold text-dark">
                InApp <br>
                <small class="text-muted" style="font-size: 0.7rem;">Inventory App</small>
            </span>
        </div>
    </div>
    
    <div class="px-3 mt-4">
        <p class="text-muted small text-uppercase fw-bold mb-2" style="font-size: 0.65rem; letter-spacing: 0.5px;">Menu Principale</p>
        <ul class="nav flex-column gap-1">
            <li class="nav-item">
                <a class="nav-link rounded text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-smart-home me-2 fs-5"></i><span>Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-settings me-2 fs-5"></i><span>Services</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-category me-2 fs-5"></i><span>Categories</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-package me-2 fs-5"></i><span>Produit</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-users me-2 fs-5"></i><span>Ressources</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link active bg-danger-subtle rounded text-danger fw-bold d-flex align-items-center" href="{{ path('app_projet_index') }}">
                    <i class="ti ti-file-code me-2 fs-5"></i><span>Projets</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-calendar-event me-2 fs-5"></i><span>Taches et Planning</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark d-flex align-items-center" href="#">
                    <i class="ti ti-device-heartbeat me-2 fs-5"></i><span>Evenements</span>
                </a>
            </li>
        </ul>
    </div>
</aside>

<main id="content" class="content mt-5 pt-5">
    <div class="container-fluid">
        <div class="row g-3 align-items-center mb-4">
            <div class="col-lg-3">
                <h2 class="fs-4 mb-0 fw-bold">Liste des Projets</h2>
            </div>
            <div class="col-lg-4">
                <div class="input-group shadow-sm border rounded-3 overflow-hidden bg-white">
                    <span class="input-group-text bg-white border-0"><i class="ti ti-search text-muted"></i></span>
                    <input type="text" id="searchInput" class="form-control border-0 ps-0" placeholder="Rechercher par nom...">
                </div>
            </div>
            <div class="col-lg-2">
                <select id="statutFilter" class="form-select border-0 shadow-sm fw-semibold text-danger">
                    <option value="">Tous les statuts</option>
                    <option value="Planifié">Planifié</option>
                    <option value="En cours">En cours</option>
                    <option value="Terminé">Terminé</option>
                    <option value="Annulé">Annulé</option>
                </select>
            </div>
            <div class="col-lg-3 text-end">
                <a href="{{ path('app_projet_new') }}" class="btn btn-danger shadow-sm px-4 fw-bold">Nouveau</a>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table align-middle mb-0" id="projetTable">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-muted small fw-bold cursor-pointer" onclick="sortTable(0)">
                                NOM DU PROJET <i class="ti ti-arrows-sort ms-1"></i>
                            </th>
                            <th class="py-3 text-muted small fw-bold text-center cursor-pointer" onclick="sortTable(1)">
                                BUDGET <i class="ti ti-arrows-sort ms-1"></i>
                            </th>
                            <th class="py-3 text-muted small fw-bold text-center">STATUT</th>
                            <th class="text-end pe-4 py-3 text-muted small fw-bold">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody id="projetTableBody">
                    {% for projet in projets %}
                        <tr class="projet-row">
                            <td class="ps-4 fw-bold projet-nom text-dark">{{ projet.nom }}</td>
                            <td class="text-success fw-bold text-center projet-budget" data-value="{{ projet.budget }}">
                                {{ projet.budget|number_format(2, ',', ' ') }} DT
                            </td>
                            <td class="text-center">
                                <span class="badge projet-statut-badge rounded-pill px-3 py-2 
                                    {% if projet.statut == 'En cours' %}bg-warning text-dark
                                    {% elseif projet.statut == 'Terminé' %}bg-success
                                    {% elseif projet.statut == 'Annulé' %}bg-danger
                                    {% else %}bg-info text-white{% endif %}">
                                    {{ projet.statut }}
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-3 border">
                                    <a href="{{ path('app_projet_show', {'id': projet.id}) }}" class="btn btn-sm btn-white"><i class="ti ti-eye text-primary"></i></a>
                                    <a href="{{ path('app_projet_edit', {'id': projet.id}) }}" class="btn btn-sm btn-white"><i class="ti ti-edit text-warning"></i></a>
                                    <a href="{{ path('app_projet_archive_action', {'id': projet.id}) }}" class="btn btn-sm btn-white" onclick="return confirm('Archiver ?')"><i class="ti ti-box-archive text-danger"></i></a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<script>
// --- LOGIQUE RECHERCHE ET FILTRE ---
const searchInput = document.getElementById('searchInput');
const statutFilter = document.getElementById('statutFilter');

function filterTable() {
    const search = searchInput.value.toLowerCase();
    const statut = statutFilter.value;
    const rows = document.querySelectorAll('.projet-row');

    rows.forEach(row => {
        const nom = row.querySelector('.projet-nom').textContent.toLowerCase();
        const statutRow = row.querySelector('.projet-statut-badge').textContent.trim();
        const matchSearch = nom.includes(search);
        const matchStatut = statut === "" || statutRow === statut;
        row.style.display = (matchSearch && matchStatut) ? "" : "none";
    });
}

searchInput.addEventListener('input', filterTable);
statutFilter.addEventListener('change', filterTable);

// --- LOGIQUE TRI ---
let sortDirection = true;
function sortTable(columnIndex) {
    const tableBody = document.getElementById("projetTableBody");
    const rows = Array.from(tableBody.querySelectorAll(".projet-row"));

    rows.sort((a, b) => {
        let valA, valB;
        if (columnIndex === 1) {
            valA = parseFloat(a.querySelector(".projet-budget").getAttribute("data-value"));
            valB = parseFloat(b.querySelector(".projet-budget").getAttribute("data-value"));
        } else {
            valA = a.children[columnIndex].textContent.toLowerCase();
            valB = b.children[columnIndex].textContent.toLowerCase();
        }
        return sortDirection ? (valA > valB ? 1 : -1) : (valA < valB ? 1 : -1);
    });

    sortDirection = !sortDirection;
    rows.forEach(row => tableBody.appendChild(row));
}
</script>

<style>
    .cursor-pointer { cursor: pointer; transition: 0.2s; }
    .cursor-pointer:hover { background-color: #fcecea !important; color: #dc3545 !important; }
</style>
{% endblock %}