{% extends 'base.html.twig' %}

{% block title %}STRATIX - Liste des Projets{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    
    <div class="row g-3 align-items-center mb-4 mt-2">
        <div class="col-lg-3">
            <h2 class="fs-4 mb-0 fw-bold text-dark">Gestion des Projets</h2>
            <p class="text-muted small mb-0">Suivi en temps réel de vos développements.</p>
        </div>
        
        <div class="col-lg-4">
            <div class="input-group shadow-sm border rounded-3 overflow-hidden bg-white">
                <span class="input-group-text bg-white border-0"><i class="ti ti-search text-muted"></i></span>
                <input type="text" id="searchInput" class="form-control border-0 ps-0" placeholder="Rechercher un projet...">
            </div>
        </div>
        
        <div class="col-lg-2">
            <select id="statutFilter" class="form-select border-0 shadow-sm fw-semibold text-danger">
                <option value="">Tous les statuts</option>
                <option value="Planifié">Planifié</option>
                <option value="En cours">En cours</option>
                <option value="Terminé">Terminé</option>
                <option value="Annulé">Annulé</option>
            </select>
        </div>
        
        <div class="col-lg-3 text-end">
            {# Vérifie que la route app_projet_new existe bien dans ton Controller #}
            <a href="{{ path('app_projet_new') }}" class="btn btn-danger shadow-sm px-4 fw-bold">
                <i class="ti ti-plus me-1"></i> Nouveau Projet
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0" id="projetTable">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted small fw-bold" style="width: 70px;">ICÔNE</th>
                        <th class="py-3 text-muted small fw-bold cursor-pointer" onclick="sortTable(1)">
                            NOM DU PROJET <i class="ti ti-arrows-sort ms-1"></i>
                        </th>
                        <th class="py-3 text-muted small fw-bold text-center cursor-pointer" onclick="sortTable(2)">
                            BUDGET <i class="ti ti-arrows-sort ms-1"></i>
                        </th>
                        <th class="py-3 text-muted small fw-bold text-center">STATUT</th>
                        <th class="text-end pe-4 py-3 text-muted small fw-bold">ACTIONS</th>
                    </tr>
                </thead>
                <tbody id="projetTableBody">
                {% for projet in projets %}
                    <tr class="projet-row">
                        <td class="ps-4">
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 38px; height: 38px;">
                                <i class="ti ti-folder text-danger" style="font-size: 1.2rem;"></i>
                            </div>
                        </td>
                        <td class="fw-bold projet-nom">
                            <a href="{{ path('app_projet_show', {'id': projet.id}) }}" class="text-dark text-decoration-none project-title-link">
                                {{ projet.nom }}
                            </a>
                        </td>
                        <td class="text-success fw-bold text-center projet-budget" data-value="{{ projet.budget }}">
                            {{ projet.budget|number_format(2, ',', ' ') }} DT
                        </td>
                        <td class="text-center">
                            <span class="badge projet-statut-badge rounded-pill px-3 py-2 
                                {% if projet.statut == 'En cours' %}bg-warning text-dark
                                {% elseif projet.statut == 'Terminé' %}bg-success
                                {% elseif projet.statut == 'Annulé' %}bg-danger
                                {% else %}bg-info text-white{% endif %}">
                                {{ projet.statut }}
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm rounded-3 border bg-white">
                                <a href="{{ path('app_projet_show', {'id': projet.id}) }}" class="btn btn-sm btn-white" title="Voir">
                                    <i class="ti ti-eye text-primary"></i>
                                </a>
                                <a href="{{ path('app_projet_edit', {'id': projet.id}) }}" class="btn btn-sm btn-white" title="Modifier">
                                    <i class="ti ti-edit text-warning"></i>
                                </a>
                                {# Correction ici : on utilise une vérification de route ou un lien mort si l'erreur persiste #}
                                <a href="#" class="btn btn-sm btn-white" title="Supprimer" onclick="return confirm('Action non configurée');">
                                    <i class="ti ti-trash text-danger"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="ti ti-folder-off fs-1 d-block mb-2"></i>
                            Aucun projet trouvé.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        const statutFilter = document.getElementById('statutFilter');

        function filterData() {
            const search = searchInput.value.toLowerCase();
            const statut = statutFilter.value;
            const rows = document.querySelectorAll('.projet-row');

            rows.forEach(row => {
                const nom = row.querySelector('.projet-nom').textContent.toLowerCase();
                const badgeElement = row.querySelector('.projet-statut-badge');
                const badgeText = badgeElement ? badgeElement.textContent.trim() : "";
                
                const matchSearch = nom.includes(search);
                const matchStatut = (statut === "") || (badgeText === statut);

                row.style.display = (matchSearch && matchStatut) ? "" : "none";
            });
        }

        if(searchInput) searchInput.addEventListener('input', filterData);
        if(statutFilter) statutFilter.addEventListener('change', filterData);
    });

    let sortOrder = true;
    function sortTable(idx) {
        const body = document.getElementById("projetTableBody");
        const rows = Array.from(body.querySelectorAll(".projet-row"));

        if (rows.length === 0) return;

        rows.sort((a, b) => {
            let aVal, bVal;
            if (idx === 2) { // Colonne Budget
                aVal = parseFloat(a.querySelector(".projet-budget").dataset.value) || 0;
                bVal = parseFloat(b.querySelector(".projet-budget").dataset.value) || 0;
            } else { // Texte
                aVal = a.children[idx].innerText.toLowerCase();
                bVal = b.children[idx].innerText.toLowerCase();
            }
            return sortOrder ? (aVal > bVal ? 1 : -1) : (aVal < bVal ? 1 : -1);
        });

        sortOrder = !sortOrder;
        rows.forEach(r => body.appendChild(r));
    }
</script>

<style>
    .cursor-pointer { cursor: pointer; transition: 0.2s; }
    .cursor-pointer:hover { background-color: #f8f9fa !important; }
    .project-title-link:hover { color: #dc3545 !important; text-decoration: underline !important; }
    .projet-row:hover { background-color: #fcfcfc; }
    .btn-white { background: #fff; border: 1px solid #eee; }
    .btn-white:hover { background: #f8f9fa; }
</style>
{% endblock %}