{# templates/projet/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}STRATIX - Modifier {{ projet.nom }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# Import de Tom Select pour la gestion flexible de l'équipe #}
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
    <style>
        :root {
            --stratix-orange: #f1b31a;
            --stratix-brown: #5d4037;
            --stratix-bg-input: #eee4cc;
        }

        .edit-card {
            border-radius: 24px;
            background-color: #fdf6e3;
            border: none;
        }

        .form-label-custom {
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--stratix-brown);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }

        .input-custom {
            background-color: var(--stratix-bg-input) !important;
            border: none !important;
            border-radius: 12px !important;
            padding: 0.8rem 1rem !important;
            transition: all 0.2s ease;
        }

        .input-custom:focus {
            box-shadow: 0 0 0 3px rgba(241, 179, 26, 0.25) !important;
            background-color: #fff !important;
        }

        /* Style spécifique pour Tom Select dans l'édition */
        .ts-control {
            border: none !important;
            background-color: var(--stratix-bg-input) !important;
            border-radius: 12px !important;
            padding: 0.5rem !important;
        }

        .btn-update {
            background-color: var(--stratix-orange);
            color: white;
            border-radius: 15px;
            padding: 1rem;
            font-weight: 700;
            border: none;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(241, 179, 26, 0.3);
        }

        .btn-update:hover {
            background-color: #d9a016;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(241, 179, 26, 0.4);
            color: white;
        }
    </style>
{% endblock %}

{% block body %}
<main id="content" class="content py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                
                <div class="card edit-card shadow-lg p-2 p-md-4">
                    <div class="card-body">
                        {# En-tête #}
                        <div class="d-flex align-items-center justify-content-between mb-5 pb-3 border-bottom border-2" style="border-color: var(--stratix-orange) !important;">
                            <div class="d-flex align-items-center">
                                <div class="bg-warning-subtle p-3 rounded-circle me-3">
                                    <i class="fas fa-pen-nib fa-lg text-warning"></i>
                                </div>
                                <div>
                                    <h3 class="fw-bold mb-0" style="color: var(--stratix-brown);">Modifier le projet</h3>
                                    <p class="text-muted small mb-0">ID: #{{ projet.id }} — Stratix Platform</p>
                                </div>
                            </div>
                            <span class="badge bg-dark rounded-pill px-3 py-2">{{ projet.statut }}</span>
                        </div>

                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                            
                            <div class="row g-4">
                                {# NOM #}
                                <div class="col-12">
                                    <label class="form-label-custom">Nom du projet</label>
                                    {{ form_widget(form.nom, {'attr': {'class': 'form-control input-custom'}}) }}
                                    <div class="text-danger small mt-1">{{ form_errors(form.nom) }}</div>
                                </div>

                                {# BUDGET & STATUT #}
                                <div class="col-md-6">
                                    <label class="form-label-custom">Budget estimé (DT)</label>
                                    {{ form_widget(form.budget, {'attr': {'class': 'form-control input-custom'}}) }}
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-custom">Statut de progression</label>
                                    {{ form_widget(form.statut, {'attr': {'class': 'form-select input-custom fw-bold'}}) }}
                                </div>

                                {# DATES #}
                                <div class="col-md-6">
                                    <label class="form-label-custom">Date de début</label>
                                    {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control input-custom'}}) }}
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-custom">Date de fin prévue</label>
                                    {{ form_widget(form.dateFin, {'attr': {'class': 'form-control input-custom'}}) }}
                                </div>

                                {# RESPONSABLE & EQUIPE #}
                                <div class="col-md-6">
                                    <label class="form-label-custom">Responsable</label>
                                    {{ form_widget(form.responsable, {'attr': {'class': 'form-select input-custom'}}) }}
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-custom">Équipe (Membres)</label>
                                    {{ form_widget(form.membres, {
                                        'attr': {
                                            'class': 'tom-select-edit', 
                                            'placeholder': 'Ajouter/Supprimer des membres...'
                                        }
                                    }) }}
                                </div>

                                {# DESCRIPTION #}
                                <div class="col-12">
                                    <label class="form-label-custom">Description détaillée</label>
                                    {{ form_widget(form.description, {'attr': {'class': 'form-control input-custom', 'rows': '4'}}) }}
                                </div>

                                {# ACTIONS #}
                                <div class="col-12 mt-5">
                                    <div class="row g-3">
                                        <div class="col-md-8">
                                            <button type="submit" class="btn btn-update w-100 shadow-sm">
                                                <i class="fas fa-save me-2"></i> ENREGISTRER LES MODIFICATIONS
                                            </button>
                                        </div>
                                        <div class="col-md-4">
                                            <a href="{{ path('app_projet_index') }}" class="btn btn-outline-dark w-100 p-3 fw-bold" style="border-radius: 15px;">
                                                ANNULER
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Activation de Tom Select pour le champ membres dans la modification
            new TomSelect(".tom-select-edit", {
                plugins: ['remove_button'],
                persist: false,
                create: false,
                maxItems: 20,
            });
        });
    </script>
{% endblock %}