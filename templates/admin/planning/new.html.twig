{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="fas fa-plus-circle"></i> {{ button_label|default('Nouveau planning') }}</h5>
    </div>
    <div class="card-body">
        
        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> {{ message }}
            </div>
        {% endfor %}

        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_label(form.date, 'Date *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.date, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
                <div class="invalid-feedback">La date est obligatoire</div>
                {{ form_errors(form.date) }}
            </div>
            
            <div class="col-md-6 mb-3">
                {{ form_label(form.typeShift, 'Type de shift *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.typeShift, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                <div class="invalid-feedback">Le type de shift est obligatoire</div>
                {{ form_errors(form.typeShift) }}
            </div>
            
            <div class="col-md-6 mb-3">
                {{ form_label(form.employeId, 'Employé *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.employeId, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                <div class="invalid-feedback">L'employé est obligatoire</div>
                {{ form_errors(form.employeId) }}
            </div>
            
            <div class="col-md-3 mb-3">
                {{ form_label(form.heureDebut, 'Heure début', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.heureDebut, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.heureDebut) }}
            </div>
            
            <div class="col-md-3 mb-3">
                {{ form_label(form.heureFin, 'Heure fin', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.heureFin, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.heureFin) }}
            </div>
            
            <div class="col-md-12 mb-3">
                {{ form_label(form.commentaire, 'Commentaire', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.commentaire, {'attr': {'class': 'form-control', 'rows': 2, 'placeholder': 'Optionnel...'}}) }}
                {{ form_errors(form.commentaire) }}
            </div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <button type="submit" class="btn btn-primary" id="submitBtn">
            <i class="fas fa-save"></i> {{ button_label|default('Enregistrer') }}
        </button>
        <a href="{{ path('app_planning_index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour à la liste
        </a>
    </div>
</div>
{{ form_end(form) }}

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('.needs-validation');
    const submitBtn = document.getElementById('submitBtn');
    
    function validateForm() {
        let isValid = true;
        const requiredFields = form.querySelectorAll('[required]');
        
        requiredFields.forEach(field => {
            if (!field.value.trim()) {
                isValid = false;
                field.classList.add('is-invalid');
            } else {
                field.classList.remove('is-invalid');
                field.classList.add('is-valid');
            }
        });
        
        // Validation date
        const dateField = document.querySelector('#planning_date');
        if (dateField && dateField.value) {
            const selectedDate = new Date(dateField.value);
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (selectedDate < today) {
                isValid = false;
                dateField.classList.add('is-invalid');
            }
        }
        
        return isValid;
    }
    
    if (submitBtn) {
        submitBtn.addEventListener('click', function(e) {
            if (!validateForm()) {
                e.preventDefault();
                alert('❌ Veuillez remplir tous les champs obligatoires (*)');
            }
        });
    }
});
</script>

<style>
    .is-invalid {
        border-color: #dc3545 !important;
        border-width: 2px !important;
    }
    .is-valid {
        border-color: #198754 !important;
    }
    .invalid-feedback {
        display: block;
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 5px;
    }
</style>