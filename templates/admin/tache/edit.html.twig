{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="fas fa-plus-circle"></i> {{ button_label|default('Nouvelle tâche') }}</h5>
    </div>
    <div class="card-body">
        
        <!-- Affichage des erreurs globales -->
        {% if form_errors(form) %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> Veuillez remplir tous les champs obligatoires
            </div>
        {% endif %}

        <div class="row">
            <!-- Titre - OBLIGATOIRE -->
            <div class="col-md-12 mb-3">
                {{ form_label(form.titre, 'Titre *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'placeholder': 'Saisir le titre de la tâche', 'required': 'required'}}) }}
                <div class="invalid-feedback">Le titre est obligatoire</div>
                {{ form_errors(form.titre) }}
            </div>
            
            <!-- Description - OBLIGATOIRE -->
            <div class="col-md-12 mb-3">
                {{ form_label(form.description, 'Description *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Description détaillée...', 'required': 'required'}}) }}
                <div class="invalid-feedback">La description est obligatoire</div>
                {{ form_errors(form.description) }}
            </div>
            
            <!-- Deadline - OBLIGATOIRE -->
            <div class="col-md-6 mb-3">
                {{ form_label(form.deadline, 'Deadline *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.deadline, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
                <div class="invalid-feedback">La deadline est obligatoire</div>
                {{ form_errors(form.deadline) }}
            </div>
            
            <!-- Statut - OBLIGATOIRE -->
            <div class="col-md-6 mb-3">
                {{ form_label(form.statut, 'Statut *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.statut, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                <div class="invalid-feedback">Le statut est obligatoire</div>
                {{ form_errors(form.statut) }}
            </div>
            
            <!-- Priorité - OBLIGATOIRE -->
            <div class="col-md-6 mb-3">
                {{ form_label(form.priorite, 'Priorité *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.priorite, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                <div class="invalid-feedback">La priorité est obligatoire</div>
                {{ form_errors(form.priorite) }}
            </div>
            
            <!-- Employé - OBLIGATOIRE -->
            <div class="col-md-6 mb-3">
                {{ form_label(form.employeId, 'Employé *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.employeId, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
                <div class="invalid-feedback">L'employé est obligatoire</div>
                {{ form_errors(form.employeId) }}
            </div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <button type="submit" class="btn btn-primary" id="submitBtn">
            <i class="fas fa-save"></i> {{ button_label|default('Enregistrer') }}
        </button>
        <a href="{{ path('app_tache_index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour à la liste
        </a>
    </div>
</div>
{{ form_end(form) }}

<script>
// Validation JavaScript côté client
(function() {
    'use strict';
    
    const form = document.querySelector('.needs-validation');
    const submitBtn = document.getElementById('submitBtn');
    
    // Fonction de validation
    function validateForm() {
        let isValid = true;
        
        // Vérifier tous les champs required
        const requiredFields = form.querySelectorAll('[required]');
        requiredFields.forEach(field => {
            if (!field.value.trim()) {
                isValid = false;
                field.classList.add('is-invalid');
            } else {
                field.classList.remove('is-invalid');
                field.classList.add('is-valid');
            }
        });
        
        // Vérifier la date
        const deadlineField = document.querySelector('#tache_deadline');
        if (deadlineField && deadlineField.value) {
            const selectedDate = new Date(deadlineField.value);
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (selectedDate < today) {
                isValid = false;
                deadlineField.classList.add('is-invalid');
                deadlineField.setCustomValidity('La date ne peut pas être dans le passé');
            } else {
                deadlineField.classList.remove('is-invalid');
                deadlineField.classList.add('is-valid');
                deadlineField.setCustomValidity('');
            }
        }
        
        return isValid;
    }
    
    // Validation au clic sur le bouton
    if (submitBtn) {
        submitBtn.addEventListener('click', function(e) {
            if (!validateForm()) {
                e.preventDefault();
                e.stopPropagation();
                alert('Veuillez remplir tous les champs obligatoires (*)');
            }
        });
    }
    
    // Validation en temps réel
    const inputs = form.querySelectorAll('input, select, textarea');
    inputs.forEach(input => {
        input.addEventListener('input', function() {
            if (this.value.trim()) {
                this.classList.remove('is-invalid');
                this.classList.add('is-valid');
            } else {
                this.classList.remove('is-valid');
                if (this.hasAttribute('required')) {
                    this.classList.add('is-invalid');
                }
            }
        });
    });
    
    // Validation au chargement
    validateForm();
})();
</script>

<style>
    .is-invalid {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
    }
    .is-valid {
        border-color: #198754 !important;
    }
    .invalid-feedback {
        display: block;
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }
</style>