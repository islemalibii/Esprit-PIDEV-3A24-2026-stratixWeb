{% extends 'admin/base_admin.html.twig' %}
{% block title %}Dashboard — Stratix{% endblock %}

{% block admin_content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-0" style="font-size:1.8rem;">Dashboard</h1>
        <p class="text-secondary mb-0" style="font-size:.95rem;">{{ "now"|date("d/m/Y") }} — Bienvenue, {{ app.user.prenom }} 👋</p>
    </div>
    <a href="{{ path('admin_user_new') }}" class="btn btn-primary">
        <i class="ti ti-plus me-1"></i> Nouvel utilisateur
    </a>
</div>

{# ── STAT CARDS ── #}
<div class="row g-3 mb-4">
    <div class="col-lg-3 col-sm-6">
        <div class="card p-4 bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-2 h-100">
            <div class="d-flex gap-3 align-items-center">
                <div class="icon-shape icon-md bg-primary text-white rounded-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="ti ti-users fs-4"></i>
                </div>
                <div>
                    <div class="text-secondary small">Total utilisateurs</div>
                    <div class="fw-bold fs-3 lh-1">{{ stats.total }}</div>
                </div>
            </div>
            <div class="progress mt-3" style="height:4px;">
                <div class="progress-bar bg-primary" style="width:100%"></div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card p-4 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-2 h-100">
            <div class="d-flex gap-3 align-items-center">
                <div class="icon-shape icon-md bg-success text-white rounded-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="ti ti-user-check fs-4"></i>
                </div>
                <div>
                    <div class="text-secondary small">Comptes actifs</div>
                    <div class="fw-bold fs-3 lh-1">{{ stats.actifs }}</div>
                </div>
            </div>
            <div class="progress mt-3" style="height:4px;">
                <div class="progress-bar bg-success" style="width:{{ stats.taux_actifs }}%"></div>
            </div>
            <div class="text-success small mt-1">{{ stats.taux_actifs }}% du total</div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card p-4 bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-2 h-100">
            <div class="d-flex gap-3 align-items-center">
                <div class="icon-shape icon-md bg-danger text-white rounded-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="ti ti-lock fs-4"></i>
                </div>
                <div>
                    <div class="text-secondary small">Verrouillés</div>
                    <div class="fw-bold fs-3 lh-1">{{ stats.locked }}</div>
                </div>
            </div>
            <div class="progress mt-3" style="height:4px;">
                <div class="progress-bar bg-danger" style="width:{{ stats.total > 0 ? (stats.locked/stats.total*100)|round : 0 }}%"></div>
            </div>
            <div class="text-danger small mt-1">{{ stats.total > 0 ? (stats.locked/stats.total*100)|round : 0 }}% du total</div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card p-4 bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-2 h-100">
            <div class="d-flex gap-3 align-items-center">
                <div class="icon-shape icon-md bg-warning text-white rounded-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="ti ti-shield fs-4"></i>
                </div>
                <div>
                    <div class="text-secondary small">Administrateurs</div>
                    <div class="fw-bold fs-3 lh-1">{{ stats.admins }}</div>
                </div>
            </div>
            <div class="progress mt-3" style="height:4px;">
                <div class="progress-bar bg-warning" style="width:{{ stats.total > 0 ? (stats.admins/stats.total*100)|round : 0 }}%"></div>
            </div>
            <div class="text-warning small mt-1">{{ stats.total > 0 ? (stats.admins/stats.total*100)|round : 0 }}% du total</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    {# ── Répartition par rôle ── #}
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-white px-4 py-3">
                <h4 class="mb-0 h6 fw-bold">Répartition par rôle</h4>
            </div>
            <div class="card-body px-4">
                {% set roleColors = {
                    'admin': 'primary', 'ceo': 'danger', 'employe': 'info',
                    'responsable_rh': 'success', 'responsable_projet': 'purple',
                    'responsable_production': 'warning'
                } %}
                {% set total = stats.total %}
                {% for role, count in roles %}
                    {% set rc = roleColors[role] ?? 'secondary' %}
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small fw-semibold">{{ role|upper }}</span>
                            <span class="small text-secondary">{{ count }} ({{ total > 0 ? (count/total*100)|round : 0 }}%)</span>
                        </div>
                        <div class="progress" style="height:6px;border-radius:4px;">
                            <div class="progress-bar bg-{{ rc }}" style="width:{{ total > 0 ? (count/total*100)|round : 0 }}%"></div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# ── Comptes verrouillés ── #}
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
                <h4 class="mb-0 h6 fw-bold">Comptes verrouillés</h4>
                <span class="badge bg-danger-subtle text-danger border border-danger border-opacity-25">{{ stats.locked }}</span>
            </div>
            {% if lockedUsers|length > 0 %}
            <ul class="list-group list-group-flush">
                {% for u in lockedUsers %}
                <li class="list-group-item d-flex align-items-center gap-3 px-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                         style="width:34px;height:34px;font-size:.75rem;background:linear-gradient(135deg,#dc2626,#ef4444);">
                        {{ u.prenom|first|upper }}{{ u.nom|first|upper }}
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold small">{{ u.nom }} {{ u.prenom }}</div>
                        <div class="text-secondary" style="font-size:.75rem;">{{ u.failedLoginAttempts ?? 0 }} tentatives</div>
                    </div>
                    <form method="post" action="{{ path('admin_user_toggle_lock', {id: u.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle'~u.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-success py-0 px-2" style="font-size:.75rem;">
                            Déverrouiller
                        </button>
                    </form>
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <div class="card-body text-center text-secondary small py-4">
                <i class="ti ti-lock-open fs-2 d-block mb-2 text-success"></i>
                Aucun compte verrouillé
            </div>
            {% endif %}
        </div>
    </div>

    {# ── Activité récente ── #}
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-white px-4 py-3">
                <h4 class="mb-0 h6 fw-bold">Activité récente</h4>
            </div>
            <ul class="list-group list-group-flush">
                {% for u in recent|slice(0,5) %}
                <li class="list-group-item d-flex align-items-center gap-3 px-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                         style="width:34px;height:34px;font-size:.75rem;background:linear-gradient(135deg,#4f46e5,#7c3aed);">
                        {{ u.prenom|first|upper }}{{ u.nom|first|upper }}
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold small">{{ u.nom }} {{ u.prenom }}</div>
                        <div class="text-secondary" style="font-size:.75rem;">{{ u.email }}</div>
                    </div>
                    {% set roleColors = {'admin':'primary','ceo':'danger','employe':'info','responsable_rh':'success','responsable_projet':'purple','responsable_production':'warning'} %}
                    {% set rc = roleColors[u.role] ?? 'secondary' %}
                    <span class="badge bg-{{ rc }}-subtle text-{{ rc }}" style="font-size:.7rem;">{{ u.role|upper }}</span>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</div>

{# ── Tableau derniers inscrits ── #}
<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
        <h4 class="mb-0 h6 fw-bold">Derniers utilisateurs inscrits</h4>
        <a href="{{ path('admin_users') }}" class="btn btn-sm btn-primary">Voir tout</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="px-4">Utilisateur</th>
                    <th>Email</th>
                    <th>Rôle</th>
                    <th>Statut</th>
                    <th>Compte</th>
                    <th class="px-4">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% set roleColors = {'admin':'primary','ceo':'danger','employe':'info','responsable_rh':'success','responsable_projet':'purple','responsable_production':'warning'} %}
            {% for u in recent %}
                {% set rc = roleColors[u.role] ?? 'secondary' %}
                <tr>
                    <td class="px-4">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                                 style="width:34px;height:34px;font-size:.75rem;background:linear-gradient(135deg,#4f46e5,#7c3aed);">
                                {{ u.prenom|first|upper }}{{ u.nom|first|upper }}
                            </div>
                            <div>
                                <div class="fw-semibold small">{{ u.nom }} {{ u.prenom }}</div>
                                <div class="text-secondary" style="font-size:.75rem;">CIN: {{ u.cin }}</div>
                            </div>
                        </div>
                    </td>
                    <td class="text-secondary small">{{ u.email }}</td>
                    <td><span class="badge bg-{{ rc }}-subtle text-{{ rc }} border border-{{ rc }} border-opacity-25">{{ u.role|upper }}</span></td>
                    <td>
                        {% if u.statut == 'actif' %}
                            <span class="badge bg-success-subtle text-success border border-success border-opacity-25">Actif</span>
                        {% else %}
                            <span class="badge bg-secondary-subtle text-secondary">{{ u.statut ?: '-' }}</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if u.isAccountLocked() %}
                            <span class="badge bg-danger-subtle text-danger">🔒 Verrouillé</span>
                        {% else %}
                            <span class="badge bg-success-subtle text-success">✓ Actif</span>
                        {% endif %}
                    </td>
                    <td class="px-4">
                        <a href="{{ path('admin_user_edit', {id: u.id}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="ti ti-edit"></i>
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
