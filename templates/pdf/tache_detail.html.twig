<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Détail Tâche #{{ tache.id }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 40px;
            color: #333;
        }
        .header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 2px solid #1f3b4c;
            padding-bottom: 10px;
        }
        .header h1 {
            color: #1f3b4c;
        }
        .card {
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            background: #f9f9f9;
        }
        .info-row {
            margin-bottom: 15px;
            display: flex;
        }
        .info-label {
            font-weight: bold;
            width: 150px;
            color: #1f3b4c;
        }
        .info-value {
            flex: 1;
        }
        .priority-high { color: #ef4444; font-weight: bold; }
        .priority-medium { color: #f59e0b; }
        .priority-low { color: #10b981; }
        .footer {
            text-align: center;
            margin-top: 30px;
            font-size: 10px;
            color: #999;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>📄 Détail de la Tâche</h1>
        <div>Exporté le : {{ date_export }}</div>
    </div>

    <div class="card">
        <div class="info-row">
            <div class="info-label">ID :</div>
            <div class="info-value">#{{ tache.id }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Titre :</div>
            <div class="info-value">{{ tache.titre }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Description :</div>
            <div class="info-value">{{ tache.description ?: 'Aucune description' }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Priorité :</div>
            <div class="info-value priority-{{ tache.priorite|lower }}">{{ tache.priorite }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Statut :</div>
            <div class="info-value">{{ tache.statut|replace({'_': ' '})|title }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Deadline :</div>
            <div class="info-value">{{ tache.deadline ? tache.deadline|date('d/m/Y') : 'Non définie' }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Employé :</div>
            <div class="info-value">{{ employeNom }}</div>
        </div>
    </div>

    <div class="footer">
        <p>Document généré automatiquement par STRATIX</p>
    </div>
</body>
</html>
