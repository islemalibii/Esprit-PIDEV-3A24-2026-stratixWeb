{% extends 'employee/base_employee.html.twig' %}
{% block title %}Modifier mon profil{% endblock %}

{% block employee_content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <a href="{{ path('employee_profile') }}" class="text-secondary text-decoration-none small">
            <i class="ti ti-arrow-left me-1"></i>Retour au profil
        </a>

        <form method="post" class="mt-3">
            <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;">
                <div class="card-header bg-white px-4 py-3 border-bottom">
                    <h6 class="fw-bold mb-0"><i class="ti ti-user me-2 text-primary"></i>Informations personnelles</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Nom *</label>
                            <input type="text" name="nom" value="{{ user.nom }}" required
                                   class="form-control {% if errors.nom is defined %}is-invalid{% endif %}">
                            {% if errors.nom is defined %}<div class="invalid-feedback">{{ errors.nom }}</div>{% endif %}
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Prénom *</label>
                            <input type="text" name="prenom" value="{{ user.prenom }}" required
                                   class="form-control {% if errors.prenom is defined %}is-invalid{% endif %}">
                            {% if errors.prenom is defined %}<div class="invalid-feedback">{{ errors.prenom }}</div>{% endif %}
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Téléphone</label>
                            <input type="text" name="tel" value="{{ user.tel }}" placeholder="8 chiffres"
                                   class="form-control {% if errors.tel is defined %}is-invalid{% endif %}">
                            {% if errors.tel is defined %}<div class="invalid-feedback">{{ errors.tel }}</div>{% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;">
                <div class="card-header bg-white px-4 py-3 border-bottom">
                    <h6 class="fw-bold mb-0"><i class="ti ti-lock me-2 text-warning"></i>Changer le mot de passe</h6>
                    <small class="text-secondary">Laisser vide pour ne pas modifier</small>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Mot de passe actuel</label>
                            <input type="password" name="current_password"
                                   class="form-control {% if errors.current_password is defined %}is-invalid{% endif %}">
                            {% if errors.current_password is defined %}<div class="invalid-feedback">{{ errors.current_password }}</div>{% endif %}
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Nouveau mot de passe</label>
                            <input type="password" name="new_password" placeholder="Min. 8 car., 1 majuscule, 1 chiffre"
                                   class="form-control {% if errors.new_password is defined %}is-invalid{% endif %}">
                            {% if errors.new_password is defined %}<div class="invalid-feedback">{{ errors.new_password }}</div>{% endif %}
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Confirmer</label>
                            <input type="password" name="confirm_password"
                                   class="form-control {% if errors.confirm_password is defined %}is-invalid{% endif %}">
                            {% if errors.confirm_password is defined %}<div class="invalid-feedback">{{ errors.confirm_password }}</div>{% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="ti ti-device-floppy me-1"></i>Enregistrer
                </button>
                <a href="{{ path('employee_profile') }}" class="btn btn-outline-secondary px-4">Annuler</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
