<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Stratix — Espace Employé{% endblock %}</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    {% block stylesheets %}
        <link rel="stylesheet" crossorigin href="/styles/app.css">
    {% endblock %}
</head>
<body>
    <div id="overlay" class="overlay"></div>

    {{ include('employee/partials/navbar.html.twig') }}
    {{ include('employee/partials/sidebar.html.twig') }}

    <main id="content" class="content py-4">
        <div class="container-fluid px-4">
            {% block employee_content %}{% endblock %}
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var dropdowns = document.querySelectorAll('[data-bs-toggle="dropdown"]');
            dropdowns.forEach(function(el) { new bootstrap.Dropdown(el); });
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>