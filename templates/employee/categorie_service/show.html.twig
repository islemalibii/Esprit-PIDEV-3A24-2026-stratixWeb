{% extends 'employee/base_employee.html.twig' %}

{% block employee_content %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Détails de la Catégorie</h1>
        <div>
            <a href="{{ path('app_employee_categorie_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour à la liste
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-6 col-lg-8">
            <div class="card shadow">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">{{ categorie_service.nom }}</h6>
                    {% if categorie_service.archive %}
                        <span class="badge bg-secondary">Archivée</span>
                    {% else %}
                        <span class="badge bg-success">Active</span>
                    {% endif %}
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong class="text-primary">Nom:</strong>
                        <p>{{ categorie_service.nom }}</p>
                    </div>

                    <div class="mb-3">
                        <strong class="text-primary">Description:</strong>
                        <p>
                            {% if categorie_service.description %}
                                {{ categorie_service.description }}
                            {% else %}
                                <span class="text-muted">Aucune description</span>
                            {% endif %}
                        </p>
                    </div>

                    <div class="mb-3">
                        <strong class="text-primary">Date de création:</strong>
                        <p>{{ categorie_service.dateCreation ? categorie_service.dateCreation|date('d/m/Y H:i') : 'Non définie' }}</p>
                    </div>

                    <div class="mb-3">
                        <strong class="text-primary">Statut:</strong>
                        <p>
                            {% if categorie_service.archive %}
                                <span class="badge bg-secondary">Archivée</span>
                            {% else %}
                                <span class="badge bg-success">Active</span>
                            {% endif %}
                        </p>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="alert alert-info mb-0">
                        <i class="fas fa-info-circle"></i> 
                        <strong>Mode consultation seule</strong> - Vous ne pouvez pas modifier cette catégorie.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
