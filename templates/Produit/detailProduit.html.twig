{% extends 'base_admin.html.twig' %}

{% block title %}Détails du Produit{% endblock %}

{% block body %}
<div class="container mt-4 mb-5" style="max-width: 700px; background-color: white; border-radius: 8px; shadow-sm; overflow: hidden; border: 1px solid #dee2e6;">
    
    <div style="background-color: #2c3e50; padding: 20px; text-align: center;">
        <h2 id="titreLabel" style="color: white; font-size: 22px; font-weight: bold; margin: 0;">
            Détails du produit : {{ produit.nom }}
        </h2>
    </div>

    <div class="p-4">
        <div class="d-flex justify-content-center mb-4">
            <div style="border: 2px solid #ddd; border-radius: 5px; padding: 5px;">
                {% if produit.imagePath %}
                    <img src="{{ asset('uploads/produits/' ~ produit.imagePath) }}" 
                         style="height: 200px; width: 200px; object-fit: contain;">
                {% else %}
                    <img src="{{ asset('images/default-product.png') }}" 
                         style="height: 200px; width: 200px; object-fit: contain; opacity: 0.5;">
                {% endif %}
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header fw-bold">Informations générales</div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Nom:</div>
                    <div class="col-8">{{ produit.nom ?: '-' }}</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Description:</div>
                    <div class="col-8 text-break">{{ produit.description ?: '-' }}</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Catégorie:</div>
                    <div class="col-8">{{ produit.categorie ?: '-' }}</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Prix:</div>
                    <div class="col-8" style="color: #27ae60; font-weight: bold;">{{ produit.prix|number_format(2, '.', ',') }} DT</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Stock:</div>
                    <div class="col-8">{{ produit.stockActuel }} (min: {{ produit.stockMin }})</div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header fw-bold">Dates</div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Date création:</div>
                    <div class="col-8">{{ produit.dateCreation ? produit.dateCreation|date('d/m/Y') : '-' }}</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Date fabrication:</div>
                    <div class="col-8">{{ produit.dateFabrication ? produit.dateFabrication|date('d/m/Y') : '-' }}</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Date péremption:</div>
                    <div class="col-8">{{ produit.datePeremption ? produit.datePeremption|date('d/m/Y') : '-' }}</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Date garantie:</div>
                    <div class="col-8">{{ produit.dateGarantie ? produit.dateGarantie|date('d/m/Y') : '-' }}</div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header fw-bold">Ressources et Détails</div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-4 fw-bold">Ressources:</div>
                    <div class="col-8">{{ produit.ressourcesNecessaires ?: '-' }}</div>
                </div>
                <div class="row">
                    <div class="col-4 fw-bold">Détails:</div>
                    <div class="col-8">
                        <div class="p-2 border rounded" style="background-color: #f9f9f9; min-height: 80px; white-space: pre-wrap;">
                            {{ produit.details ?: 'Aucun détail supplémentaire' }}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% set statut = produit.statut %} {# Suppose que tu as ajouté la méthode getStatut() dans l'entité #}
        <div class="text-center p-2 mb-4 rounded fw-bold {{ statut.class|default('bg-light text-dark') }}">
            {{ statut.text|default('Statut non défini') }}
        </div>

        <div class="d-flex justify-content-center">
            <a href="{{ path('produit_index') }}" class="btn px-5 fw-bold" style="background-color: #3498db; color: white;">
                Fermer
            </a>
        </div>
    </div>
</div>
{% endblock %}