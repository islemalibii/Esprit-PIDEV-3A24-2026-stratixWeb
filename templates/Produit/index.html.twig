{# 1. ON CHANGE L'HÉRITAGE ICI #}
{% extends 'admin/base_admin.html.twig' %}

{% block title %}Stratix - Liste des Produits{% endblock %}

{# 2. ON UTILISE LE BLOC CONTENU DE TA SIDEBAR #}
{% block admin_content %}
<div class="container-fluid mt-4"> {# container-fluid est mieux pour les tableaux larges #}
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            
            {# BARRE DE RECHERCHE #}
            <form method="GET" action="{{ path('produit_index') }}" class="row g-2 mb-4">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">🔍</span>
                        <input type="text" name="q" value="{{ searchTerm }}" class="form-control border-start-0" placeholder="Rechercher un produit (nom, catégorie...)...">
                    </div>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn text-white" style="background-color: #3498db;">Rechercher</button>
                    <a href="{{ path('produit_index') }}" class="btn text-white" style="background-color: #95a5a6;">Effacer</a>
                </div>
            </form>

            {# ENTÊTE ET ACTIONS #}
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="h4 mb-0 fw-bold" style="color: #2c3e50;">Gestion des Produits</h2>
                <div class="d-flex gap-2">
                    <div class="dropdown">
                        <button class="btn text-white dropdown-toggle" type="button" data-bs-toggle="dropdown" style="background-color: #9b59b6;">
                            🔽 Trier par
                        </button>
                        <ul class="dropdown-menu shadow border-0">
                            <li><a class="dropdown-item" href="{{ path('produit_index', {sort: 'prix', direction: 'asc'}) }}">Prix croissant</a></li>
                            <li><a class="dropdown-item" href="{{ path('produit_index', {sort: 'prix', direction: 'desc'}) }}">Prix décroissant</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{{ path('produit_index', {sort: 'nom', direction: 'asc'}) }}">Nom (A-Z)</a></li>
                        </ul>
                    </div>
                    <a href="{{ path('produit_new') }}" class="btn text-white fw-bold" style="background-color: #27ae60;">➕ Nouveau Produit</a>
                    <a href="{{ path('produit_pdf') }}" class="btn btn-danger shadow-sm">Export PDF 📄</a>
                </div>
            </div>

            {# TABLEAU #}
            <div class="table-responsive rounded border shadow-sm bg-white">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Produit</th>
                            <th>Prix</th>
                            <th>Stock Actuel</th>
                            <th>Statut</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for produit in produits %}
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">{{ produit.nom }}</div>
                                    <small class="text-muted text-uppercase" style="font-size: 0.75rem;">{{ produit.categorie }}</small>
                                </td>
                                <td class="fw-bold text-primary">{{ produit.prix|number_format(2, ',', ' ') }} DT</td>
                                <td>
                                    <span class="fw-semibold">{{ produit.stockActuel }}</span> 
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">min: {{ produit.stockMin }}</small>
                                </td>
                                <td>
                                    {# Utilisation sécurisée des propriétés de statut #}
                                    <span class="badge {{ produit.statut.class|default('bg-secondary') }} p-2">
                                        {{ produit.statut.text|default('Inconnu') }}
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm">
                                        <a href="{{ path('produit_edit', {id: produit.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier">✏</a>
                                        <form method="post" action="{{ path('produit_delete', {id: produit.id}) }}" style="display:inline-block;" onsubmit="return confirm('Voulez-vous vraiment supprimer ce produit de Stratix ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" title="Supprimer">🗑</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted fst-italic">Aucun produit ne correspond à votre recherche.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# STATISTIQUES (Footer) #}
            <div class="row g-0 text-center mt-4 p-3 border rounded shadow-sm" style="background-color: #f8f9fa;">
                <div class="col-md-4 border-end border-2">
                    <div class="small text-muted mb-1 text-uppercase fw-bold" style="letter-spacing: 1px;">Total Produits</div>
                    <div class="fw-bold h4 mb-0 text-dark">{{ stats.total|default(0) }}</div>
                </div>
                <div class="col-md-4 border-end border-2">
                    <div class="small text-muted mb-1 text-uppercase fw-bold" style="letter-spacing: 1px;">Stock Faible</div>
                    <div class="fw-bold h4 mb-0 text-danger">{{ stats.stockFaible|default(0) }}</div>
                </div>
                <div class="col-md-4">
                    <div class="small text-muted mb-1 text-uppercase fw-bold" style="letter-spacing: 1px;">Valeur du Stock</div>
                    <div class="fw-bold h4 mb-0 text-success">{{ stats.valeurStock|default(0)|number_format(2, ',', ' ') }} DT</div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}